# Source trees (vendored upstream + forks; reproducible via scripts/bootstrap.sh)
/src/

# Build intermediates
/build/
tools/rsx-cg-compiler/build/

# Per-sample build output
samples/**/build/
samples/**/build-lp64/
samples/**/cmake-build/
samples/**/*.elf
samples/**/*.self
samples/**/*.fake.self
samples/**/*.map
samples/**/*.pkg
samples/**/*.gnpdrm.pkg

# Derived sample assets copied from sdk/assets at pkg-build time.
samples/sysutil/hello-ppu-png/pkg_files/USRDIR/ps3dk.png

# Staging prefix ($PS3DEV install root)
/stage/

# Proprietary reference material — MUST NEVER be committed.
# Contains pointers, mount instructions, and the actual reference mount
# used privately for API coverage/oracle work.  Everything under
# reference/ stays local to each developer's machine.
/reference/

# Tarball cache
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
*.zip

# rsx-cg-compiler generated embed file (regenerated by Python at CMake-configure time)
tools/rsx-cg-compiler/src/donor/builtin_shader_header_embedded.inc

# Generated SDK version header — produced by scripts/version.sh at install
# time.  Should never appear inside the source tree (it lives at
# $PS3DK/ppu/include/cell/sdk_version.h after install).
/sdk/include/cell/sdk_version.h
/tools/rsx-cg-compiler/src/version.h

# Build tool outputs
*.o
*.a
*.d
*.so
a.out

# Patch series backups (rebase / bisect intermediates)
patches/**/series.bak
patches/**/series.bak.*

# nidgen extracted audit YAMLs -- reference-SDK analysis
# artifacts.  The production NID yaml under
# tools/nidgen/nids/extracted/<lib>_stub.yaml is what ships; *_audit.yaml
# carries the raw nm / archive inventory and stays local.
tools/nidgen/nids/extracted/*_audit.yaml

