# Source trees (vendored upstream + forks; reproducible via scripts/bootstrap.sh)
/src/

# Build intermediates
/build/
tools/rsx-cg-compiler/build/

# Per-sample build output
samples/*/build/
samples/*/*.elf
samples/*/*.fake.self
samples/*/*.pkg
samples/*/*.gnpdrm.pkg

# Staging prefix ($PS3DEV install root)
/stage/

# Proprietary reference material — MUST NEVER be committed.
# Contains pointers, mount instructions, and the actual reference mount
# used privately for API coverage/oracle work.  Everything under
# reference/ stays local to each developer's machine.
/reference/

# Tarball cache
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
*.zip

# rsx-cg-compiler generated embed file (regenerated by Python at CMake-configure time)
tools/rsx-cg-compiler/src/donor/builtin_shader_header_embedded.inc

# Build tool outputs
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.exp
*.lib
*.obj
*.pdb
*.self
*.sprx
*.pkg
*.ko
*.map

# Rust / Cargo (tools/nidgen, stubgen, coverage-report)
target/
Cargo.lock
!/tools/Cargo.lock
!/tools/*/Cargo.lock

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
!/CMakeLists.txt
!/cmake/**/*.cmake

# Editor / IDE
.vscode/
.vs/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs and diagnostics
*.log
*.tmp
.build-stamps/

# CI scratch
.ccache/
.sccache/

# Claude Code local-only settings (per-user; team-shared settings.json is OK to commit)
.claude/settings.local.json

# Private developer notes — phase/stage narrative kept out of the public tree.
/docs/dev-notes.md

# Session / planning / provenance docs that assume access to the reference
# cell SDK or carry too much internal phase narrative for the public tree.
# Kept locally; never tracked.
/docs/HANDOFF.md
/docs/phase-0-status.md
/docs/plan.md
/docs/building-sony-sdk-samples.md
/docs/building-reference-samples.md

# rsx-cg-compiler reverse-engineering diary + diff-test harness.
# Both are local-only: REVERSE_ENGINEERING.md will be replaced by a public
# ARCHITECTURE.md; run_diff.sh drives a byte-match against the reference
# compiler and depends on a proprietary tool.
/tools/rsx-cg-compiler/docs/REVERSE_ENGINEERING.md
/tools/rsx-cg-compiler/tests/

# Claude project-context file — tracks internal phase narrative, kept
