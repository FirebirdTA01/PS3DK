Subject: [PATCH] ppu/include: <cell/gcm.h> command-emitter forwarders

Phase 7 step 3.  Adds <cell/gcm/gcm_command_c.h> with the most-used
Sony cellGcm command emitters (~25 functions: Flush/Finish, surface,
clear, labels, color/depth/blend state, viewport, cull) forwarding
to PSL1GHT's rsx* equivalents in librsx.  Wires the new header into
<cell/gcm.h> via #include at the bottom (matches Sony's reference
gcm.h which includes <cell/gcm/gcm_command_c.h> in the same place).

Also adds a CellGcmSurface typedef to <cell/gcm.h> over PSL1GHT's
gcmSurface — both have the same 33-field byte-identical layout so
user code that fills a CellGcmSurface and passes it to
cellGcmSetSurface gets reinterpreted as gcmSurface * by the inline
forwarder.

Sony spelling note: cellGcmSetWriteBackEndLabel uses capital E in
"BackEnd" (unlike PSL1GHT's lowercase Backend).  Forwarder preserves
Sony's capitalisation so source compiles unchanged.

Validated end-to-end by samples/hello-ppu-cellgcm-clear (ported from
hello-ppu-rsx-clear with Sony names everywhere a forwarder exists).

Deferred (separate follow-up commits): the draw/texture/vertex-program
emitter family (cellGcmSetVertexProgram, SetVertexDataArray,
SetDrawArrays, SetTexture, SetTextureFilter, etc. — several hundred
functions in Sony's gcm_prototypes_sub.h).

diff --git a/ppu/include/cell/gcm.h b/ppu/include/cell/gcm.h
--- a/ppu/include/cell/gcm.h
+++ b/ppu/include/cell/gcm.h
@@ -73,6 +73,12 @@ typedef gcmContextCallback   CellGcmContextCallback;
  * coreFreq/Frequency).  Field-name spellings differ; cast through. */
 typedef gcmConfiguration     CellGcmConfig;
 
+/* CellGcmSurface aliased onto PSL1GHT's gcmSurface.  Layouts are
+ * byte-identical (same 33 fields in the same order — verified against
+ * Sony's gcm_struct.h); user code that fills a CellGcmSurface and
+ * passes it to cellGcmSetSurface gets reinterpreted as gcmSurface * by
+ * the cellGcmSetSurface forwarder. */
+typedef gcmSurface           CellGcmSurface;
+
 /* Sony's "current context" global.  PSL1GHT exposes gGcmContext under
  * the same semantics; we re-bind via #define so user-side l-value uses
  * (gCellGcmCurrentContext->current = ..., etc.) and rvalue reads both
@@ -266,4 +272,9 @@ static inline uint32_t *cellGcmGetLabelAddress(uint8_t index)
 }
 #endif
 
+/* Command-emitter forwarders (Phase 7 step 3).  Sony source includes
+ * the command-emitter family transitively through <cell/gcm.h>; we
+ * preserve that. */
+#include <cell/gcm/gcm_command_c.h>
+
 #endif /* __PSL1GHT_CELL_GCM_H__ */

diff --git a/ppu/include/cell/gcm/gcm_command_c.h b/ppu/include/cell/gcm/gcm_command_c.h
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/ppu/include/cell/gcm/gcm_command_c.h
@@ -0,0 +1,211 @@
+/*! \file cell/gcm/gcm_command_c.h
+ \brief Sony-SDK-source-compat libgcm command-emitter forwarders.
+
+  Phase 7 step 3.  Maps the most-used Sony cellGcmSet/cellGcmFlush/
+  cellGcmFinish command emitters to PSL1GHT's rsx equivalents in
+  librsx.  Sony's command-emitter family is generated by macro from
+  <cell/gcm/gcm_prototypes_sub.h> in 6 variants (Safe/Unsafe x
+  Inline/Outline x Run/Measure); we only ship the safe/outline variant
+  here since that's what user source actually calls.
+
+  Function signatures match Sony exactly: each takes
+  `CellGcmContextData *thisContext` as first arg (== gcmContextData *,
+  byte-identical alias from <cell/gcm.h>), then the GPU command args.
+
+  Covered (~25 functions):
+    Sync         Flush / Finish / SetReferenceCommand
+    Surface      SetSurface / SetClearSurface / SetClearColor /
+                 SetClearDepthStencil
+    Labels       SetWaitLabel / SetWriteCommandLabel /
+                 SetWriteBackEndLabel / SetWriteTextureLabel
+    State        SetColorMask / SetColorMaskMrt / SetDepthFunc /
+                 SetDepthTestEnable / SetDepthMask /
+                 SetBlendEnable / SetShadeModel
+    Geometry     SetViewport / SetCullFace / SetFrontFace /
+                 SetCullFaceEnable / SetUserClipPlaneControl
+
+  Deferred (massive surface, mostly draw/texture/vertex-program):
+    cellGcmSetVertexProgram / SetFragmentProgram / SetVertexDataArray /
+    SetDrawArrays / SetDrawIndexArray / SetTexture / SetTextureControl /
+    SetTextureFilter / SetTransferImage / SetTransferData / etc.
+    These bind to PSL1GHT's rsxSetVertexProgram / etc. — same forwarder
+    pattern, just larger surface.
+
+  Note Sony spelling of "BackEnd" with capital E (vs PSL1GHT's
+  "Backend") — preserved exactly so Sony source compiles.
+*/
+
+#ifndef __PSL1GHT_CELL_GCM_COMMAND_C_H__
+#define __PSL1GHT_CELL_GCM_COMMAND_C_H__
+
+#include <stdint.h>
+#include <ppu-types.h>
+#include <rsx/gcm_sys.h>
+#include <rsx/commands.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* CellGcmContextData / CellGcmConfig come from <cell/gcm.h>; this
+ * header is normally included transitively from there.  For direct
+ * inclusion, the typedef is brought in by rsx/gcm_sys.h via
+ * gcmContextData (CellGcmContextData is its alias). */
+
+/* ==========================================================
+ * Sync
+ * ========================================================== */
+
+static inline void cellGcmFlush(CellGcmContextData *thisContext)
+{
+	rsxFlushBuffer(thisContext);
+}
+
+static inline void cellGcmFlushUnsafe(CellGcmContextData *thisContext)
+{
+	rsxFlushBufferUnsafe(thisContext);
+}
+
+static inline void cellGcmFinish(CellGcmContextData *thisContext, uint32_t ref)
+{
+	rsxFinish(thisContext, ref);
+}
+
+static inline void cellGcmFinishUnsafe(CellGcmContextData *thisContext, uint32_t ref)
+{
+	rsxFinishUnsafe(thisContext, ref);
+}
+
+static inline void cellGcmSetReferenceCommand(CellGcmContextData *thisContext, uint32_t ref)
+{
+	rsxSetReferenceCommand(thisContext, ref);
+}
+
+/* ==========================================================
+ * Surface / clear
+ * ========================================================== */
+
+static inline void cellGcmSetSurface(CellGcmContextData *thisContext, const CellGcmSurface *surface)
+{
+	rsxSetSurface(thisContext, (const gcmSurface *)surface);
+}
+
+static inline void cellGcmSetClearColor(CellGcmContextData *thisContext, uint32_t color)
+{
+	rsxSetClearColor(thisContext, color);
+}
+
+static inline void cellGcmSetClearDepthStencil(CellGcmContextData *thisContext, uint32_t value)
+{
+	rsxSetClearDepthStencil(thisContext, value);
+}
+
+static inline void cellGcmSetClearSurface(CellGcmContextData *thisContext, uint32_t mask)
+{
+	rsxClearSurface(thisContext, mask);
+}
+
+/* ==========================================================
+ * Labels (fence-style sync points in the command stream)
+ * ========================================================== */
+
+static inline void cellGcmSetWaitLabel(CellGcmContextData *thisContext, uint8_t index, uint32_t value)
+{
+	rsxSetWaitLabel(thisContext, index, value);
+}
+
+static inline void cellGcmSetWriteCommandLabel(CellGcmContextData *thisContext, uint8_t index, uint32_t value)
+{
+	rsxSetWriteCommandLabel(thisContext, index, value);
+}
+
+/* Note Sony spelling: BackEnd (capital E) vs PSL1GHT's Backend. */
+static inline void cellGcmSetWriteBackEndLabel(CellGcmContextData *thisContext, uint8_t index, uint32_t value)
+{
+	rsxSetWriteBackendLabel(thisContext, index, value);
+}
+
+static inline void cellGcmSetWriteTextureLabel(CellGcmContextData *thisContext, uint8_t index, uint32_t value)
+{
+	rsxSetWriteTextureLabel(thisContext, index, value);
+}
+
+/* ==========================================================
+ * Color / depth state
+ * ========================================================== */
+
+static inline void cellGcmSetColorMask(CellGcmContextData *thisContext, uint32_t mask)
+{
+	rsxSetColorMask(thisContext, mask);
+}
+
+static inline void cellGcmSetColorMaskMrt(CellGcmContextData *thisContext, uint32_t mask)
+{
+	rsxSetColorMaskMrt(thisContext, mask);
+}
+
+static inline void cellGcmSetDepthFunc(CellGcmContextData *thisContext, uint32_t func)
+{
+	rsxSetDepthFunc(thisContext, func);
+}
+
+static inline void cellGcmSetDepthTestEnable(CellGcmContextData *thisContext, uint32_t enable)
+{
+	rsxSetDepthTestEnable(thisContext, enable);
+}
+
+static inline void cellGcmSetDepthMask(CellGcmContextData *thisContext, uint32_t mask)
+{
+	rsxSetDepthWriteEnable(thisContext, mask);
+}
+
+static inline void cellGcmSetBlendEnable(CellGcmContextData *thisContext, uint32_t enable)
+{
+	rsxSetBlendEnable(thisContext, enable);
+}
+
+static inline void cellGcmSetShadeModel(CellGcmContextData *thisContext, uint32_t model)
+{
+	rsxSetShadeModel(thisContext, model);
+}
+
+/* ==========================================================
+ * Geometry / viewport / culling
+ * ========================================================== */
+
+static inline void cellGcmSetViewport(CellGcmContextData *thisContext,
+                                      uint16_t x, uint16_t y, uint16_t w, uint16_t h,
+                                      float min_z, float max_z,
+                                      const float scale[4], const float offset[4])
+{
+	rsxSetViewport(thisContext, x, y, w, h, min_z, max_z, scale, offset);
+}
+
+static inline void cellGcmSetCullFace(CellGcmContextData *thisContext, uint32_t cfm)
+{
+	rsxSetCullFace(thisContext, cfm);
+}
+
+static inline void cellGcmSetFrontFace(CellGcmContextData *thisContext, uint32_t dir)
+{
+	rsxSetFrontFace(thisContext, dir);
+}
+
+static inline void cellGcmSetCullFaceEnable(CellGcmContextData *thisContext, uint32_t enable)
+{
+	rsxSetCullFaceEnable(thisContext, enable);
+}
+
+static inline void cellGcmSetUserClipPlaneControl(CellGcmContextData *thisContext,
+                                                  uint32_t plane0, uint32_t plane1,
+                                                  uint32_t plane2, uint32_t plane3,
+                                                  uint32_t plane4, uint32_t plane5)
+{
+	rsxSetUserClipPlaneControl(thisContext, plane0, plane1, plane2, plane3, plane4, plane5);
+}
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* __PSL1GHT_CELL_GCM_COMMAND_C_H__ */
