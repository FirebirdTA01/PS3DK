From: PS3 Custom Toolchain <noreply@example.invalid>
Subject: [PATCH] sysutil/video.h: union-alias resolution / resolutionId in display-mode + config

PSL1GHT's video-out structs expose the resolution-id field as
`.resolution`; Sony sample code writes it as `.resolutionId`.  Same
u8, same offset, same value set.  An anonymous union lets both
spellings resolve against the same storage.

Mirror of the antiAlias/antialias fix in 0025; same pattern, same
rationale — Sony sample code that only pulls <sysutil/video.h> (via
our cell/cell_video_out.h surface) compiles unchanged against the
shared struct.

Signed-off-by: PS3 Custom Toolchain <noreply@example.invalid>
---
 ppu/include/sysutil/video.h | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/ppu/include/sysutil/video.h b/ppu/include/sysutil/video.h
--- a/ppu/include/sysutil/video.h
+++ b/ppu/include/sysutil/video.h
@@ -89,7 +89,7 @@ typedef struct _videodisplaymode
     - \c VIDEO_RESOLUTION_480
     - \c VIDEO_RESOLUTION_576
 */
-    u8 resolution;
+    union { u8 resolution; u8 resolutionId; };
 /*! \brief Scan mode.
     \todo more explanations needed. */
     u8 scanMode;
@@ -150,7 +150,7 @@ typedef struct _videoconfig
     - \c VIDEO_RESOLUTION_480
     - \c VIDEO_RESOLUTION_576
 */
-    u8 resolution;
+    union { u8 resolution; u8 resolutionId; };
 /*! \brief video buffer format.

     The possible values are:
