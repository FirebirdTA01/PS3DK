Subject: [PATCH] sys/process.h: emit crash_dump_param_addr via R_PPC64_ADDR32

Phase 3 task #7.  After patch 0008, sys_process_param_t had a trailing
u32 crash_dump_param_addr field, but SYS_PROCESS_PARAM initialised it
to 0 because there is no way to write `(uint32_t)(uintptr_t)&func` as a
C constant expression under ELFv1 PPC64 — function descriptors resolve
at link time, and GCC refuses the narrowing cast for a static init.
Sony's reference SDK side-steps this entirely by using SN Systems'
PS3-32-bit-pointer ABI where the cast IS constant; we can't assume
that in standard GCC output.

The fix is to emit the whole 36-byte struct from `__asm__ (".section
.sys_proc_param, ... .long __sys_process_crash_dump_param")` at file
scope.  The assembler lowers the final `.long` to an R_PPC64_ADDR32
relocation, the linker writes the low 32 bits of the symbol's OPD
descriptor address at link time, and weak-unresolved (no user
definition) gives 0 — exactly what Sony's loader expects for the
"no crash-dump callback" case.

This replaces the C struct initializer form of SYS_PROCESS_PARAM /
_OVLM / _FIXED with a single shared helper
(__PSL1GHT_SYS_PROCESS_PARAM_EMIT) that takes the ppc_seg flavour as
its differentiator.  The sys_process_param_t struct type itself stays
as declared; user code that does
`extern sys_process_param_t __sys_process_param;` reads the 36-byte
region emitted by the asm through the C type and sees the right
values.

To activate a crash-dump callback, user code defines:

    void __sys_process_crash_dump_param(void) { ... }

and nothing else changes — the macro's `.weak` declaration + the
R_PPC64_ADDR32 relocation do the rest.  Hello-ppu-sony-abi still
passes with `crash_dump_param_addr = 0` (no callback defined).

Verified end-to-end on the current install tree: hello-ppu-sony-abi
relinks cleanly, objdump -s -j .sys_proc_param shows the same 36-byte
section as before (last word = 0 because no callback defined in this
sample), and a scratch TU that does define the callback has the
relocation resolve to the OPD address.

--- a/ppu/include/sys/process.h
+++ b/ppu/include/sys/process.h
@@ -47,6 +47,42 @@
 /*! \brief set stack size to 1 megabyte. */
 #define SYS_PROCESS_SPAWN_STACK_SIZE_1M		 0x70

+/* Helpers for emitting the .sys_proc_param section via inline asm so the
+ * trailing crash_dump_param_addr field can be a link-time R_PPC64_ADDR32
+ * relocation against __sys_process_crash_dump_param — a C struct
+ * initializer can't hold that value because (uint32_t)(uintptr_t)&func
+ * isn't a constant expression under ELFv1 PPC64 (function descriptors
+ * resolve at link time).  If __sys_process_crash_dump_param is weak-
+ * unresolved (no user definition), the relocation fills in 0 and the
+ * PS3 loader skips the callback.
+ *
+ * Declaring the weak extern inside the macro via __asm__(".weak ...")
+ * keeps the pseudo-declaration at file scope without dragging a typed
+ * C declaration into every translation unit that includes this header.
+ */
+#define __PSL1GHT_PROC_PARAM_STRINGIFY_EXPAND(x) #x
+#define __PSL1GHT_PROC_PARAM_STRINGIFY(x) __PSL1GHT_PROC_PARAM_STRINGIFY_EXPAND(x)
+
+#define __PSL1GHT_SYS_PROCESS_PARAM_EMIT(prio, stacksize, ppc_seg)           \
+	__asm__ (                                                                 \
+		".weak __sys_process_crash_dump_param\n"                              \
+		".section \".sys_proc_param\",\"a\",@progbits\n"                      \
+		".balign 8\n"                                                         \
+		".globl __sys_process_param\n"                                        \
+		".type __sys_process_param, @object\n"                                \
+		".size __sys_process_param, 36\n"                                     \
+		"__sys_process_param:\n"                                              \
+		".long 36\n"                                                          \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(SYS_PROCESS_SPAWN_MAGIC) "\n" \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(SYS_PROCESS_SPAWN_VERSION_330) "\n"  \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(SYS_PROCESS_SPAWN_SDK_VERSION_UNKNOWN) "\n" \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(prio) "\n"                   \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(stacksize) "\n"              \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(SYS_PROCESS_SPAWN_MALLOC_PAGE_SIZE_1M) "\n" \
+		".long "  __PSL1GHT_PROC_PARAM_STRINGIFY(ppc_seg) "\n"                \
+		".long __sys_process_crash_dump_param\n"                              \
+	)
+
 /* initial stack size
  * \param size
  * \param magic
@@ -65,43 +101,13 @@
 \param stacksize stack size
 */
 #define SYS_PROCESS_PARAM(prio,stacksize) \
-	sys_process_param_t __sys_process_param __attribute__((aligned(8), section(".sys_proc_param"), unused)) = { \
-		sizeof(sys_process_param_t), \
-		SYS_PROCESS_SPAWN_MAGIC, \
-		SYS_PROCESS_SPAWN_VERSION_330, \
-		SYS_PROCESS_SPAWN_SDK_VERSION_UNKNOWN, \
-		prio, \
-		stacksize, \
-		SYS_PROCESS_SPAWN_MALLOC_PAGE_SIZE_1M, \
-		SYS_PROCESS_SPAWN_PPC_SEG_DEFAULT, \
-		0 \
-	};
+	__PSL1GHT_SYS_PROCESS_PARAM_EMIT(prio, stacksize, SYS_PROCESS_SPAWN_PPC_SEG_DEFAULT)

 #define SYS_PROCESS_PARAM_OVLM(prio,stacksize) \
-	sys_process_param_t __sys_process_param __attribute__((aligned(8), section(".sys_proc_param"), unused)) = { \
-		sizeof(sys_process_param_t), \
-		SYS_PROCESS_SPAWN_MAGIC, \
-		SYS_PROCESS_SPAWN_VERSION_330, \
-		SYS_PROCESS_SPAWN_SDK_VERSION_UNKNOWN, \
-		prio, \
-		stacksize, \
-		SYS_PROCESS_SPAWN_MALLOC_PAGE_SIZE_1M, \
-		SYS_PROCESS_SPAWN_PPC_SEG_OVLM, \
-		0 \
-	};
+	__PSL1GHT_SYS_PROCESS_PARAM_EMIT(prio, stacksize, SYS_PROCESS_SPAWN_PPC_SEG_OVLM)

 #define SYS_PROCESS_PARAM_FIXED(prio,stacksize) \
-	sys_process_param_t __sys_process_param __attribute__((aligned(8), section(".sys_proc_param"), unused)) = { \
-		sizeof(sys_process_param_t), \
-		SYS_PROCESS_SPAWN_MAGIC, \
-		SYS_PROCESS_SPAWN_VERSION_330, \
-		SYS_PROCESS_SPAWN_SDK_VERSION_UNKNOWN, \
-		prio, \
-		stacksize, \
-		SYS_PROCESS_SPAWN_MALLOC_PAGE_SIZE_1M, \
-		SYS_PROCESS_SPAWN_PPC_SEG_PRX, \
-		0 \
-	};
+	__PSL1GHT_SYS_PROCESS_PARAM_EMIT(prio, stacksize, SYS_PROCESS_SPAWN_PPC_SEG_PRX)
