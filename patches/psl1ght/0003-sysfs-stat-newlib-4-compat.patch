Subject: [PATCH] lv2/sysfs.h + librt/fstat.c: survive newlib's st_*time macros

Newlib 4.4's <sys/stat.h> unconditionally declares timespec members
st_atim/st_mtim/st_ctim and then #defines st_atime -> st_atim.tv_sec
(same for st_mtime/st_ctime).  Those macros bleed into every
subsequent struct declaration that happens to reuse the same member
names -- notably PSL1GHT's sysFSStat, whose three time_t fields use
the legacy names.  Without intervention the struct declaration in
sysfs.h fails with

  error: expected ':', ',', ';', '}' or '__attribute__' before '.' token
  time_t st_atime;

since the preprocessor rewrites st_atime into st_atim.tv_sec mid-
declaration.

Three changes, in one patch because they are tightly coupled:

  1. sysfs.h wraps the sysFSStat typedef in #pragma push_macro /
     #undef / #pragma pop_macro on the three legacy names.  Inside
     the wrap the struct parses correctly; callers outside the
     header retain newlib's st_*time -> st_*tim.tv_sec rewrite.

  2. sysfs.h pulls <sys/param.h> so MAXPATHLEN is visible at the
     sysFSDirent typedef's declaration site (newlib 4.4 stopped
     transitively exposing it via <unistd.h> / <time.h>).

  3. librt/fstat.c drops the three st_*time macros TU-locally
     (after all headers have been included) so that src->st_atime
     reads sysFSStat's literal field.  The destination side
     writes dst->st_atim.tv_sec explicitly because newlib's
     struct stat holds timespec members, not bare time_t.

diff --git a/ppu/include/lv2/sysfs.h b/ppu/include/lv2/sysfs.h
index 9bf0035..66e386c 100644
--- a/ppu/include/lv2/sysfs.h
+++ b/ppu/include/lv2/sysfs.h
@@ -3,6 +3,7 @@

 #include <time.h>
 #include <unistd.h>
+#include <sys/param.h>
 #include <ppu-types.h>

 // Open Flags
@@ -23,6 +24,18 @@
 	extern "C" {
 #endif

+/* newlib's <sys/stat.h> defines st_atime / st_mtime / st_ctime as
+ * macros expanding to st_atim.tv_sec etc.  The sysFSStat struct below
+ * uses the same names as literal field identifiers.  Push the macros
+ * out of the way around this declaration so the struct parses
+ * correctly, then restore them for any following newlib code.  */
+#pragma push_macro("st_atime")
+#pragma push_macro("st_mtime")
+#pragma push_macro("st_ctime")
+#undef st_atime
+#undef st_mtime
+#undef st_ctime
+
 typedef struct _sys_fs_stat
 {
 	s32 st_mode;
@@ -35,6 +48,10 @@ typedef struct _sys_fs_stat
 	u64 st_blksize;
 } __attribute__((packed)) sysFSStat;

+#pragma pop_macro("st_ctime")
+#pragma pop_macro("st_mtime")
+#pragma pop_macro("st_atime")
+
 typedef struct _sys_fs_dirent
 {
 	u8 d_type;
diff --git a/ppu/librt/fstat.c b/ppu/librt/fstat.c
index e59f50a..ec74c98 100644
--- a/ppu/librt/fstat.c
+++ b/ppu/librt/fstat.c
@@ -9,15 +9,25 @@

 #include <sys/file.h>

+/* Newlib's <sys/stat.h> defines st_atime / st_mtime / st_ctime as
+ * macros expanding to st_atim.tv_sec etc.  sysfs.h already push_macro's
+ * them around its struct declaration so the struct parses correctly.
+ * Inside this TU we want to read sysFSStat's literal field (src->st_atime)
+ * rather than have the newlib macro rewrite the access, so drop the
+ * macros now -- after sysfs.h has finished declaring the struct.  */
+#undef st_atime
+#undef st_mtime
+#undef st_ctime
+
 static void convertLv2Stat(struct stat *dst,sysFSStat *src)
 {
 	memset(dst,0,sizeof(struct stat));
 	dst->st_mode = src->st_mode;
 	dst->st_uid = src->st_uid;
 	dst->st_gid = src->st_gid;
-	dst->st_atime = src->st_atime;
-	dst->st_mtime = src->st_mtime;
-	dst->st_ctime = src->st_ctime;
+	dst->st_atim.tv_sec = src->st_atime;
+	dst->st_mtim.tv_sec = src->st_mtime;
+	dst->st_ctim.tv_sec = src->st_ctime;
 	dst->st_size = src->st_size;
 	dst->st_blksize = src->st_blksize;
