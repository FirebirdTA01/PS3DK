Subject: [PATCH] lv2/sysfs.h, librt/fstat.c: guard Sony-style st_*time members

sysFSStat and Sony's CellFsStat both use the member names st_atime/
st_mtime/st_ctime (typed as time_t).  Newlib 4.4's <sys/stat.h> is
POSIX-2008-style: for non-SVR4 targets it declares timespec members
st_atim/st_mtim/st_ctim, and then unconditionally #defines
st_atime -> st_atim.tv_sec (etc).  That macro rewrites EVERY
subsequent st_atime token, including unrelated struct declarations
and accesses.

Sony avoids the collision by shipping their own <sys/stat.h> that
never defines those macros; we do not yet own sys/stat.h wholesale
(would require shadowing the full newlib libc surface and bloats
the patch set).  Interpose locally instead:

  * sysfs.h pulls <sys/param.h> so MAXPATHLEN is visible at
    struct-declaration time.
  * sysfs.h wraps the sysFSStat typedef in
    #pragma push_macro("st_atime") / #undef / pop_macro so the
    struct members declare as literal fields regardless of what
    newlib's sys/stat.h did before this header was pulled.  POSIX
    callers outside sysfs.h see the macro unchanged (push/pop
    restores the prior state).
  * fstat.c #undefs the three macros TU-wide and writes through
    dst->st_atim.tv_sec explicitly; this keeps src->st_atime a
    literal-field access on sysFSStat and leaves dst accessing
    newlib's literal timespec members.

When Phase 3 ships a PSL1GHT-owned <sys/stat.h> matching Sony's
layout, these push/pop/undef guards can be removed wholesale.

diff --git a/ppu/include/lv2/sysfs.h b/ppu/include/lv2/sysfs.h
index 9bf0035..484c35e 100644
--- a/ppu/include/lv2/sysfs.h
+++ b/ppu/include/lv2/sysfs.h
@@ -3,6 +3,7 @@
 
 #include <time.h>
 #include <unistd.h>
+#include <sys/param.h>
 #include <ppu-types.h>
 
 // Open Flags
@@ -23,6 +24,16 @@
 	extern "C" {
 #endif
 
+/* Keep Sony-style member names (st_atime/st_mtime/st_ctime) even when
+ * newlib 4.4's sys/stat.h has rewritten those tokens to st_atim.tv_sec
+ * etc.  See patches/psl1ght/0005 for rationale. */
+#pragma push_macro("st_atime")
+#pragma push_macro("st_mtime")
+#pragma push_macro("st_ctime")
+#undef st_atime
+#undef st_mtime
+#undef st_ctime
+
 typedef struct _sys_fs_stat
 {
 	s32 st_mode;
@@ -35,6 +46,10 @@ typedef struct _sys_fs_stat
 	u64 st_blksize;
 } __attribute__((packed)) sysFSStat;
 
+#pragma pop_macro("st_ctime")
+#pragma pop_macro("st_mtime")
+#pragma pop_macro("st_atime")
+
 typedef struct _sys_fs_dirent
 {
 	u8 d_type;
diff --git a/ppu/librt/fstat.c b/ppu/librt/fstat.c
index e59f50a..c35d85c 100644
--- a/ppu/librt/fstat.c
+++ b/ppu/librt/fstat.c
@@ -9,15 +9,24 @@
 
 #include <sys/file.h>
 
+/* Disable newlib's st_*time -> st_*tim.tv_sec rewrite inside this TU so
+ * that `src->st_atime` reads sysFSStat's literal field.  The dst side
+ * (newlib's struct stat) has literal st_atim/st_mtim/st_ctim timespec
+ * members; we write through tv_sec explicitly to avoid relying on the
+ * macro we just removed. */
+#undef st_atime
+#undef st_mtime
+#undef st_ctime
+
 static void convertLv2Stat(struct stat *dst,sysFSStat *src)
 {
 	memset(dst,0,sizeof(struct stat));
 	dst->st_mode = src->st_mode;
 	dst->st_uid = src->st_uid;
 	dst->st_gid = src->st_gid;
-	dst->st_atime = src->st_atime;
-	dst->st_mtime = src->st_mtime;
-	dst->st_ctime = src->st_ctime;
+	dst->st_atim.tv_sec = src->st_atime;
+	dst->st_mtim.tv_sec = src->st_mtime;
+	dst->st_ctim.tv_sec = src->st_ctime;
 	dst->st_size = src->st_size;
 	dst->st_blksize = src->st_blksize;
 
