Subject: [PATCH] ppu/include: add <sys/sony_process_param.h>

Ship a Sony-layout alternative to PSL1GHT's own <sys/process.h> for code
that must produce SELFs the Sony reference SDK 475.001 loader accepts.

The two layouts diverge:

                           PSL1GHT's sys_process_param_t    Sony's sys_process_param_t
  sizeof                   32                               36
  version constant         0x00009000  (VERSION_090)        0x00330000 (VERSION_330_0)
  trailing field           —                                uint32_t crash_dump_param_addr

Sony's loader rejects mismatched size/version pairs at SELF load time,
so code using PSL1GHT's SYS_PROCESS_PARAM(...) macro produces binaries
that (a) still happen to run on RPCS3 (permissive) and (b) are not
guaranteed to run on a retail/CFW PS3 with a firmware-3.30+ loader.

This patch installs a new, additive header under the SONY_* namespace
so there is no collision with PSL1GHT's existing macros or struct tag.
Samples and libraries that want Sony-ABI correctness do:

    #include <sys/sony_process_param.h>
    SONY_PROCESS_PARAM(1001, 0x10000);

The struct's crash_dump_param_addr is initialized to 0 ("no callback")
because `(uint32_t)(uintptr_t)&sym` is not a C constant-initialiser
under ELFv1 PPC64 — function descriptors resolve at link time.  A
followup patch will introduce a .S stub that emits the section with
an R_PPC64_ADDR32 relocation, at which point this header can grow a
non-zero pointer variant.  Until then, a zero address tells Sony's
loader to skip the crash-dump callback, matching the behaviour when
the weak symbol is unresolved.

PSL1GHT's own <sys/process.h> is left untouched — this patch is purely
additive.  A separate tree-wide migration to the Sony layout is a
Phase 3 v3 RFC item.

diff --git a/ppu/include/sys/sony_process_param.h b/ppu/include/sys/sony_process_param.h
new file mode 100644
--- /dev/null
+++ b/ppu/include/sys/sony_process_param.h
@@ -0,0 +1,71 @@
+/*
+ * sys/sony_process_param.h — Sony SDK 475.001 .sys_proc_param layout.
+ *
+ * Clean-room header.  Describes the shape of the data Sony's PS3 loader
+ * reads from the .sys_proc_param ELF section.  Authoritative source is
+ * the reference SDK 475.001's <sys/process.h>; this header restates the
+ * layout in our own words and namespace (SONY_*) so it can coexist with
+ * PSL1GHT's <sys/process.h>.
+ *
+ * Divergences from PSL1GHT's sys_process_param_t:
+ *   - 9 fields / 36 bytes (PSL1GHT = 8 / 32).  The trailing field is
+ *     the address of a weak __sys_process_crash_dump_param symbol the
+ *     loader calls on process crash.  Zero == no callback.
+ *   - version constant 0x00330000 (firmware 3.30+ layout), not
+ *     0x00009000.  Sony's loader on firmware 3.30+ rejects mismatched
+ *     version with a protocol error at SELF load time.
+ *
+ * Use this header instead of <sys/process.h> when ABI correctness
+ * against retail/CFW PS3 firmware matters.  A tree-wide migration that
+ * replaces PSL1GHT's <sys/process.h> with the Sony layout is a Phase 3
+ * v3 RFC item; until then, callers opt in explicitly.
+ */
+
+#ifndef __SYS_SONY_PROCESS_PARAM_H__
+#define __SYS_SONY_PROCESS_PARAM_H__
+
+#include <stdint.h>
+
+#define SONY_PROCESS_PARAM_MAGIC                    0x13bcc5f6u
+#define SONY_PROCESS_PARAM_VERSION_330_0            0x00330000u
+#define SONY_PROCESS_PARAM_MALLOC_PAGE_SIZE_1M      0x00100000u
+#define SONY_PROCESS_PARAM_PPC_SEG_DEFAULT          0x00000000u
+#define SONY_PROCESS_PARAM_SDK_VERSION_UNKNOWN      0xffffffffu
+
+typedef struct sony_process_param {
+	uint32_t size;                   /* sizeof(this struct), = 36 */
+	uint32_t magic;                  /* SONY_PROCESS_PARAM_MAGIC */
+	uint32_t version;                /* _VERSION_330_0 */
+	uint32_t sdk_version;            /* CELL_SDK_VERSION or _UNKNOWN */
+	int32_t  primary_prio;           /* 1000 = normal */
+	uint32_t primary_stacksize;      /* 4 KiB .. 1 MiB */
+	uint32_t malloc_pagesize;        /* _MALLOC_PAGE_SIZE_1M typical */
+	uint32_t ppc_seg;                /* _PPC_SEG_DEFAULT typical */
+	uint32_t crash_dump_param_addr;  /* 0 == no callback */
+} sony_process_param_t;
+
+/*
+ * crash_dump_param_addr is hardcoded 0 below.  `(uint32_t)&sym` is not
+ * a constant-initialiser under ELFv1 PPC64 (function descriptors
+ * resolve at link time).  A follow-up .S stub with an R_PPC64_ADDR32
+ * relocation will give this field a real pointer value; until then,
+ * zero matches the "weak symbol unresolved" semantics of Sony's SDK.
+ */
+
+#define SONY_PROCESS_PARAM_SECTION \
+	__attribute__((aligned(8), section(".sys_proc_param"), unused))
+
+#define SONY_PROCESS_PARAM(prio, stack_size)                                  \
+	sony_process_param_t __sys_process_param SONY_PROCESS_PARAM_SECTION = {   \
+		sizeof(sony_process_param_t),                                         \
+		SONY_PROCESS_PARAM_MAGIC,                                             \
+		SONY_PROCESS_PARAM_VERSION_330_0,                                     \
+		SONY_PROCESS_PARAM_SDK_VERSION_UNKNOWN,                               \
+		(prio),                                                               \
+		(stack_size),                                                         \
+		SONY_PROCESS_PARAM_MALLOC_PAGE_SIZE_1M,                               \
+		SONY_PROCESS_PARAM_PPC_SEG_DEFAULT,                                   \
+		0u,                                                                   \
+	}
+
+#endif /* __SYS_SONY_PROCESS_PARAM_H__ */
