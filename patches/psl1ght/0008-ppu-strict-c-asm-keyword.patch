From: PS3 Custom Toolchain <noreply@anthropic.com>
Date: 2026-04-24
Subject: [PATCH] ppu-{asm,lv2}.h: use __asm__ keyword for std-C99/C++17 compat

The PSL1GHT-stock copies of ppu-asm.h (low-level memory access
primitives) and ppu-lv2.h (lv2 syscall wrappers) use the bare GCC
extension keyword `asm` rather than its standards-conformant alias
`__asm__`.  Under `-std=c99` or `-std=c++17` the bare keyword is
not recognised, which makes any reference-SDK-style sample using
those flags fail to compile through any header that pulls these in
(typically through <sys/process.h> -> <ppu-lv2.h>).

Both keywords are GNU extensions; `__asm__` is the form that
survives strict-mode parsing.  No semantics change, just a string
substitution.  Affects:

  ppu-asm.h:  10x `asm volatile`           -> `__asm__ __volatile__`
  ppu-lv2.h: 81x `register u64 X asm("N")` -> `register u64 X __asm__("N")`

After the patch, the same source compiles unchanged under
-std=gnu99 / -std=gnu++17 / -std=c99 / -std=c++17.

---

--- a/ppu/include/ppu-asm.h
+++ b/ppu/include/ppu-asm.h
@@ -19,45 +19,45 @@
 
 #define __build_opd32(opd64,opd32) __extension__ \
 	({register unsigned long long func,rtoc; \
-	asm volatile("ld %0,0(%2); stw %0,0(%3); ld %1,8(%2); stw %1,4(%3)" : "=&r"(func),"=&r"(rtoc) : "b"((opd64)), "b"((opd32)) : "memory"); \
+	__asm__ __volatile__("ld %0,0(%2); stw %0,0(%3); ld %1,8(%2); stw %1,4(%3)" : "=&r"(func),"=&r"(rtoc) : "b"((opd64)), "b"((opd32)) : "memory"); \
 	(u32)((u64)(opd32)); \
 	})
 
 #define __read8(addr) __extension__ \
 	({register unsigned char result; \
-	asm volatile ("lbz %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
+	__asm__ __volatile__ ("lbz %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
 	result;})
 
 #define __read16(addr) __extension__ \
 	({register unsigned short result; \
-	asm volatile ("lhz %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
+	__asm__ __volatile__ ("lhz %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
 	result;})
 
 #define __read32(addr) __extension__ \
 	({register unsigned int result; \
-	asm volatile ("lwz %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
+	__asm__ __volatile__ ("lwz %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
 	result;})
 
 #define __read64(addr) __extension__ \
 	({register unsigned long long result; \
-	asm volatile ("ld %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
+	__asm__ __volatile__ ("ld %0,0(%1); sync" : "=r"(result) : "b"((addr))); \
 	result;})
 
 #define __write8(addr,val) \
-	asm volatile("stb %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
+	__asm__ __volatile__("stb %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
 
 #define __write16(addr,val) \
-	asm volatile("sth %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
+	__asm__ __volatile__("sth %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
 
 #define __write32(addr,val) \
-	asm volatile("stw %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
+	__asm__ __volatile__("stw %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
 
 #define __write64(addr,val) \
-	asm volatile("std %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
+	__asm__ __volatile__("std %0,0(%1); eieio" : : "r"((val)), "b"((addr)) : "memory")
 
 #define __gettime() __extension__ \
 	({register unsigned long long tb; \
-	asm volatile("1: mftb %[current_tb]; cmpwi 7,%[current_tb],0; beq- 7,1b" : [current_tb] "=r"(tb) : : "cr7"); \
+	__asm__ __volatile__("1: mftb %[current_tb]; cmpwi 7,%[current_tb],0; beq- 7,1b" : [current_tb] "=r"(tb) : : "cr7"); \
 	tb;})
 
