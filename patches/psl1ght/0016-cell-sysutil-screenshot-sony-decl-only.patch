Subject: [PATCH] ppu/include: <cell/sysutil_screenshot.h> — Sony-compat declarations

Sixth Phase 6 SDK header.  Declaration-only: PSL1GHT ships no
runtime wrappers for libsysutil_screenshot, so a full Sony-name
stub archive (nidgen archive + trampoline file) is Phase 6.5
scope.  Source that INCLUDES this header compiles; any call to
cellScreenShot* will fail at link time with a clear
undefined-reference error until 6.5 lands.

Covered (for source-compat):
  - CELL_SCREENSHOT_OK / ERROR_INTERNAL / _PARAM / _DECODE /
    _NOSPACE / _UNSUPPORTED_COLOR_FORMAT (error codes).
  - CELL_SCREENSHOT_PHOTO_TITLE_MAX_LENGTH / GAME_TITLE_MAX_LENGTH /
    GAME_COMMENT_MAX_SIZE.
  - struct CellScreenShotSetParam.
  - extern declarations for cellScreenShotEnable / Disable /
    SetParameter / SetOverlayImage.

Runtime test path is queued under Phase 6.5 as the first full-
Sony-stub-archive validation — it exercises the nidgen archive
pipeline end-to-end (previous Phase 6 forwarders piggyback on
PSL1GHT's pre-existing SPRX stubs; screenshot has none, so it
gets us the fresh code path).

diff --git a/ppu/include/cell/sysutil_screenshot.h b/ppu/include/cell/sysutil_screenshot.h
new file mode 100644
index 0000000..cf68b1b
--- /dev/null
+++ b/ppu/include/cell/sysutil_screenshot.h
@@ -0,0 +1,63 @@
+/*! \file cell/sysutil_screenshot.h
+ \brief Sony-SDK-source-compat cellScreenShot API.
+
+  Declaration-only header for Sony's screenshot SPRX surface.  PSL1GHT
+  ships no wrappers for libsysutil_screenshot; a full Sony-name stub
+  archive (generated by `nidgen archive` with matching trampolines)
+  is Phase 6.5 scope.  Until that lands, user code that INCLUDES
+  this header compiles; user code that CALLS these functions will
+  fail at link time with a clear undefined-reference error.
+
+  Target FNIDs (verified against reference/sony-sdk/.../libsysutil_screenshot_stub.a
+  and tools/nidgen/nids/extracted/libsysutil_screenshot_stub.yaml):
+    cellScreenShotEnable            0x2f85c715    (TODO Phase 6.5 — verify extraction)
+    cellScreenShotDisable           0x2f85c715    (TODO Phase 6.5 — verify extraction)
+    cellScreenShotSetParameter      0x06e71cd6
+    cellScreenShotSetOverlayImage   0x74e86d90
+*/
+
+#ifndef __PSL1GHT_CELL_SYSUTIL_SCREENSHOT_H__
+#define __PSL1GHT_CELL_SYSUTIL_SCREENSHOT_H__
+
+#include <stdint.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* Return + error codes. */
+#define CELL_SCREENSHOT_OK                              0
+#define CELL_SCREENSHOT_ERROR_INTERNAL                  0x8002d101
+#define CELL_SCREENSHOT_ERROR_PARAM                     0x8002d102
+#define CELL_SCREENSHOT_ERROR_DECODE                    0x8002d103
+#define CELL_SCREENSHOT_ERROR_NOSPACE                   0x8002d104
+#define CELL_SCREENSHOT_ERROR_UNSUPPORTED_COLOR_FORMAT  0x8002d105
+
+/* Sizes. */
+enum {
+	CELL_SCREENSHOT_PHOTO_TITLE_MAX_LENGTH  = 64,
+	CELL_SCREENSHOT_GAME_TITLE_MAX_LENGTH   = 64,
+	CELL_SCREENSHOT_GAME_COMMENT_MAX_SIZE   = 1024,
+};
+
+/* Parameters attached to subsequent screenshot captures. */
+typedef struct CellScreenShotSetParam {
+	const char *photo_title;
+	const char *game_title;
+	const char *game_comment;
+	void *reserved;
+} CellScreenShotSetParam;
+
+/* Function declarations — Phase 6.5 provides the stub archive that
+ * defines these symbols. */
+int cellScreenShotEnable(void);
+int cellScreenShotDisable(void);
+int cellScreenShotSetParameter(const CellScreenShotSetParam *param);
+int cellScreenShotSetOverlayImage(const char *srcDir, const char *srcFile,
+                                  int32_t offset_x, int32_t offset_y);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* __PSL1GHT_CELL_SYSUTIL_SCREENSHOT_H__ */
