+/* PSL1GHT libraries: the %:getenv() spec function reads $PSL1GHT at
+   build time.  --start-group / --end-group resolve circular deps
+   between newlib, lv2 stubs, and libsysbase.  */
+#define LIB_LV2_SPEC \
+  "-L %:getenv(PSL1GHT /ppu/lib) --start-group -lsysbase -lc -lrt -llv2 --end-group"
+
+#define STARTFILE_LV2_SPEC \
+  "lv2-crti.o%s crtbegin.o%s lv2-crt0.o%s lv2-sprx.o%s"
+
+#define ENDFILE_LV2_SPEC \
+  "crtend.o%s lv2-crtn.o%s"
+
+#define LINK_START_LV2_SPEC "-T lv2.ld%s"
+
+#define LINK_OS_LV2_SPEC32 "-m elf32ppc"
+#define LINK_OS_LV2_SPEC64 "-m elf64ppc"
+
+#define CPP_OS_LV2_SPEC \
+  "-D__lv2ppu__ -ffunction-sections -fdata-sections"
