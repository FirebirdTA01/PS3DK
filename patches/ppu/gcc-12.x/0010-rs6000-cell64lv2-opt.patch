--- a/gcc/config/rs6000/cell64lv2.opt
+++ b/gcc/config/rs6000/cell64lv2.opt
@@ -0,0 +1,28 @@
+; Options specific to the powerpc64-ps3-elf hybrid ABI.
+;
+; The chip is always 64-bit (PowerPC64 ISA, ELF64 file format).
+; The data model is selectable: ILP32 by default (32-bit pointer,
+; long, and size_t in a 64-bit ELF container), LP64 with -mlp64
+; (64-bit pointer, long, and size_t).
