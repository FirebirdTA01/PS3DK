diff --git a/gcc/config/rs6000/rs6000.cc b/gcc/config/rs6000/rs6000.cc
index f5db6436d..0a38214eb 100644
--- a/gcc/config/rs6000/rs6000.cc
+++ b/gcc/config/rs6000/rs6000.cc
@@ -3694,12 +3694,14 @@ rs6000_option_override_internal (bool global_init_p)
   /* Set the pointer size.  */
-  if (TARGET_64BIT)
+  /* Pointer width follows the data model selected by -mlp64; the 64-bit
+     ISA is always available regardless. */
+  if (TARGET_LP64)
     {
       rs6000_pmode = DImode;
       rs6000_pointer_size = 64;
     }
   else
     {
       rs6000_pmode = SImode;
       rs6000_pointer_size = 32;
     }
 
@@ -28880,6 +28882,23 @@ rs6000_opaque_type_invalid_use_p (gimple *stmt)
   return false;
 }

+#ifdef POWERPC_CELL64LV2
+/* PS3 / Cell64 LV2: allow SImode pointers on a 64-bit target so that
+   32-bit effective-address code works correctly.  */
+
+#undef TARGET_VALID_POINTER_MODE
+#define TARGET_VALID_POINTER_MODE rs6000_cell64lv2_valid_pointer_mode
+
+static bool
+rs6000_cell64lv2_valid_pointer_mode (scalar_int_mode mode)
+{
+  return (mode == SImode
+	  || (TARGET_LP64 && mode == DImode)
+	  || mode == ptr_mode
+	  || mode == Pmode);
+}
+#endif
+
 struct gcc_target targetm = TARGET_INITIALIZER;

 #include "gt-rs6000.h"
