+#ifdef POWERPC_CELL64LV2
+/* PS3 / Cell64 LV2: allow SImode pointers on a 64-bit target so that
+   32-bit effective-address code works correctly.  */
+
+#undef TARGET_VALID_POINTER_MODE
+#define TARGET_VALID_POINTER_MODE rs6000_cell64lv2_valid_pointer_mode
+
+static bool
+rs6000_cell64lv2_valid_pointer_mode (scalar_int_mode mode)
+{
+  return (mode == SImode
+	  || (TARGET_64BIT && mode == DImode)
+	  || mode == ptr_mode
+	  || mode == Pmode);
+}
+#endif
