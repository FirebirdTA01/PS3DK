From: PS3 Custom Toolchain
Subject: [PATCH] rs6000: emit CellOS Lv-2 compact (8-byte) function descriptors

The Lv-2 ABI uses an 8-byte compact function descriptor
    [entry_ea_32, toc_ea_32]
in .opd, not the upstream PPC64 ELFv1 24-byte three-doubleword form.
The matching indirect-call instruction sequence reads both fields
with lwz (32-bit load, zero-extends).  See docs/abi/cellos-lv2-abi-spec.md
section 2 and docs/abi/section-reference.md section 1.

This patch makes GCC's rs6000 backend emit the compact form when
built for the CellOS Lv-2 target (gated on POWERPC_CELL64LV2).
Four hunks across two files.  Standard ppc64-elf builds (Linux,
FreeBSD, bare-metal) see no change.

--- a/gcc/config/rs6000/rs6000.cc
+++ b/gcc/config/rs6000/rs6000.cc
@@ -14579,9 +14579,17 @@
   const char *ptrload = TARGET_64BIT ? "d" : "wz";
 
   if (DEFAULT_ABI == ABI_AIX)
+#ifdef POWERPC_CELL64LV2
+    /* CellOS Lv-2 compact OPD: TOC is a 32-bit EA at descriptor+4.
+       Read with lwz (zero-extends into full r2).  */
+    s += sprintf (s,
+		  "lwz 2,%%%u\n\t",
+		  funop + 3);
+#else
     s += sprintf (s,
 		  "l%s 2,%%%u\n\t",
 		  ptrload, funop + 3);
+#endif
 
   /* We don't need the extra code to stop indirect call speculation if
      calling via LR.  */
@@ -20826,6 +20834,36 @@
 {
   if (TARGET_64BIT && DEFAULT_ABI != ABI_ELFv2)
     {
+#ifdef POWERPC_CELL64LV2
+      /* CellOS Lv-2 compact function descriptor: 8 bytes
+	 [entry_ea_32, toc_ea_32], 4-byte aligned.  See
+	 docs/abi/cellos-lv2-abi-spec.md section 2.  */
+      fputs ("\t.section\t\".opd\",\"aw\"\n\t.align 2\n", file);
+      ASM_OUTPUT_LABEL (file, name);
+      fputs ("\t.long\t", file);
+      rs6000_output_function_entry (file, name);
+      fputs (",.TOC.\n\t.previous\n", file);
+      if (DOT_SYMBOLS)
+	{
+	  fputs ("\t.size\t", file);
+	  assemble_name (file, name);
+	  fputs (",8\n\t.type\t.", file);
+	  assemble_name (file, name);
+	  fputs (",@function\n", file);
+	  if (TREE_PUBLIC (decl) && ! DECL_WEAK (decl))
+	    {
+	      fputs ("\t.globl\t.", file);
+	      assemble_name (file, name);
+	      putc ('\n', file);
+	    }
+	}
+      else
+	ASM_OUTPUT_TYPE_DIRECTIVE (file, name, "function");
+      ASM_DECLARE_RESULT (file, DECL_RESULT (decl));
+      rs6000_output_function_entry (file, name);
+      fputs (":\n", file);
+      return;
+#endif
       fputs ("\t.section\t\".opd\",\"aw\"\n\t.align 3\n", file);
       ASM_OUTPUT_LABEL (file, name);
       fputs (DOUBLE_INT_ASM_OP, file);
@@ -25558,7 +25596,46 @@
 	     contains a value to place in the static chain register (r11).
 	     Note that if we load the static chain, our "trampoline" need
 	     not have any executable code.  */
+#ifdef POWERPC_CELL64LV2
+	  /* CellOS Lv-2 compact OPD: 8-byte descriptor laid out as
+	     [entry_ea_32, toc_ea_32].  Load both fields with lwz (32-bit,
+	     zero-extends into the full 64-bit register).  There is no env /
+	     static-chain slot to load.  */
+	  func = force_reg (Pmode, func);
+	  func_addr = gen_reg_rtx (Pmode);
+	  {
+	    /* Two-step load: SImode load from memory, then
+	       zero-extend into Pmode.  GCC's peephole optimizer merges
+	       the pair into a single lwz in output.  */
+	    rtx tmp_si = gen_reg_rtx (SImode);
+	    emit_move_insn (tmp_si, gen_rtx_MEM (SImode, func));
+	    if (Pmode == DImode)
+	      emit_insn (gen_zero_extendsidi2 (func_addr, tmp_si));
+	    else
+	      emit_move_insn (func_addr, tmp_si);
+	  }
+
+	  {
+	    rtx ctr_reg = gen_rtx_REG (Pmode, CTR_REGNO);
+	    emit_move_insn (ctr_reg, func_addr);
+	    func_addr = ctr_reg;
+	  }
 
+	  {
+	    /* TOC field at descriptor+4.  We keep the MEM mode Pmode so
+	       the call_indirect_aix insn pattern (which requires a
+	       Pmode memory_operand for the toc_load slot) still matches;
+	       the template in rs6000_indirect_call_template_1 emits
+	       `lwz 2,%N` under POWERPC_CELL64LV2 so only 4 bytes are
+	       actually read at runtime.  */
+	    rtx func_toc_offset = GEN_INT (4);
+	    rtx func_toc_mem = gen_rtx_MEM (Pmode,
+					    gen_rtx_PLUS (Pmode, func,
+							  func_toc_offset));
+	    toc_load = gen_rtx_USE (VOIDmode, func_toc_mem);
+	  }
+	  /* No static-chain slot in compact OPD; abi_reg stays NULL.  */
+#else
 	  /* Load up address of the actual function.  */
 	  func = force_reg (Pmode, func);
 	  func_addr = gen_reg_rtx (Pmode);
@@ -25597,6 +25671,7 @@
 	      emit_move_insn (sc_reg, func_sc_mem);
 	      abi_reg = sc_reg;
 	    }
+#endif
 	}
     }
   else
--- a/gcc/config/rs6000/ppc-asm.h
+++ b/gcc/config/rs6000/ppc-asm.h
@@ -289,6 +289,23 @@
 
 #elif defined (__powerpc64__)
 
+#if defined (POWERPC_CELL64LV2) || defined (__CELL_OS_LV2__)
+/* CellOS Lv-2 compact 8-byte function descriptor
+   [entry_ea_32, toc_ea_32].  */
+#define FUNC_NAME(name) GLUE(.,name)
+#define JUMP_TARGET(name) FUNC_NAME(name)
+#define FUNC_START(name) \
+	.section ".opd","aw"; \
+	.align 2; \
+name: \
+	.long GLUE(.,name); \
+	.long .TOC.; \
+	.previous; \
+	.type GLUE(.,name),@function; \
+	.globl name; \
+	.globl GLUE(.,name); \
+GLUE(.,name):
+#else
 #define FUNC_NAME(name) GLUE(.,name)
 #define JUMP_TARGET(name) FUNC_NAME(name)
 #define FUNC_START(name) \
@@ -302,6 +319,7 @@
 	.globl name; \
 	.globl GLUE(.,name); \
 GLUE(.,name):
+#endif
 
 #define HIDDEN_FUNC(name) \
   FUNC_START(name) \
