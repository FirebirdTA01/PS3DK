Gate stdint limit macros for C++ unless explicitly requested.

C99 §7.18 defines the limit macros in <stdint.h>.  In C++ translation
units, the long-standing __STDC_LIMIT_MACROS convention is that those
macros are only exposed when the caller defines __STDC_LIMIT_MACROS
before including the header.
Honor that gate for newlib's integer limit block while leaving the type
definitions visible in all modes.

This prevents C++98 namespace collisions with sample-side identifiers
such as SIZE_MAX while preserving the normal C behavior.

diff --git a/newlib/libc/include/stdint.h b/newlib/libc/include/stdint.h
index 3d430d5..acde5e1 100644
--- a/newlib/libc/include/stdint.h
+++ b/newlib/libc/include/stdint.h
@@ -65,6 +65,8 @@ typedef __int_fast64_t int_fast64_t;
 #define __int_fast64_t_defined 1
 #endif
 
+#if !defined(__cplusplus) || defined(__STDC_LIMIT_MACROS)
+
 #ifdef __INTPTR_TYPE__
 #define INTPTR_MIN (-__INTPTR_MAX__ - 1)
 #define INTPTR_MAX (__INTPTR_MAX__)
@@ -332,6 +334,8 @@ typedef __int_fast64_t int_fast64_t;
 #define WINT_MIN (0U)
 #endif
 
+#endif /* !__cplusplus || __STDC_LIMIT_MACROS */
+
 /** Macros for minimum-width integer constant expressions */
 #ifdef __INT8_C
 #define INT8_C(x) __INT8_C(x)
