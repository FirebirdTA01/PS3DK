--- /dev/null
+++ b/libgloss/libsysbase/_exit.c
@@ -0,0 +1,15 @@
+#include <limits.h>
+#include "config.h"
+#include <_ansi.h>
+#include <_syslist.h>
+#include <sys/syscalls.h>
+
+_VOID
+_DEFUN(_exit,(rc),
+	   int rc)
+{
+	if(__syscalls.exit)
+		__syscalls.exit(rc);
+
+	while(1);
+}
diff --git a/libgloss/libsysbase/abort.c b/libgloss/libsysbase/abort.c
