// FP ADD: varying + uniform, single instruction.
//
// sce-cgc lowers to:
//   ADDR R0, tint, f[COL0];         # src0=CONST(inlined tint), src1=INPUT(COL0)
//   <16 bytes zero-initialised — runtime patches tint>
//
// Operand-order canonicalisation: regardless of whether source code
// writes `vcol + tint` or `tint + vcol`, sce-cgc emits src0=CONST,
// src1=INPUT.  No FENCBR — sce-cgc only emits FENCBR before pure
// const-reading MOVs (not before mixed INPUT+CONST arithmetic).
void main(
    float4 vcol      : COLOR,
    uniform float4 tint,
    out float4 color : COLOR)
{
    color = vcol + tint;
}
