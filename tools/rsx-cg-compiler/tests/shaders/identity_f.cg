// Simplest NV40 fragment shader: pass interpolated COLOR0 through to
// the pixel output.  Mirrors the fpshader.cg in Sony's gcm/basic sample;
// compiles to a single MOVR writing R0 from the f[COL0] varying.
// Byte-exact target is the floor of rsx-cg-compiler stage 4 work.
void main(
    float4 color_in      : COLOR,
    out float4 color_out : COLOR)
{
    color_out = color_in;
}
