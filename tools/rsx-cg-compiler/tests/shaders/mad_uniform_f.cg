// FP MAD fusion: `vcol * uniform + uniform`.
//
// sce-cgc lowers this to a four-block sequence:
//
//   MOVH H0, f[COL0];        # promote varying to fp16
//   MOVR R1, b;              # preload ADDEND uniform (NOT multiplier)
//   <16-byte zero block — runtime patches b>
//   FENCBR ;
//   MADR R0, H0, a, R1;      # R0 = H0 * {a inline} + R1
//   <16-byte zero block — runtime patches a>
//
// 416-byte container.  Scheduling rule: when BOTH Add operands are
// uniforms, sce-cgc preloads the ADDEND into R1 and inlines the
// MULTIPLIER at MAD.SRC1.  Contrast with mad_literal_f.cg where the
// literal (unnamed) gets the inline slot.
void main(
    float4 vcol : COLOR,
    uniform float4 a,
    uniform float4 b,
    out float4 color : COLOR)
{
    color = vcol * a + b;
}
