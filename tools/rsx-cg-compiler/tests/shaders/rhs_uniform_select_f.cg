// Ternary select with a scalar-uniform RHS comparison threshold.
//
// Byte-exact structure is the same as ternary_select_f.cg, except
// the SGT's inline block after it is a zero-initialised uniform
// slot (with an embedded-const offset entry for the runtime to
// patch), not a literal `{k,0,0,0}` vec4.  Source-1 swizzle stays
// `.xxxx` since the uniform's .x is the compare value regardless.
void main(
    float4 vcol       : COLOR,
    uniform float thr,
    uniform float4 a,
    uniform float4 b,
    out float4 color  : COLOR)
{
    color = (vcol.x > thr) ? a : b;
}
