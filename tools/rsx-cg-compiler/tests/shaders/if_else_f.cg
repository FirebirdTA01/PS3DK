// Simple if/else diamond that resolves to a per-semantic write.
// Cg front-end emits explicit CondBranch + then/else blocks; the
// nv40_if_convert pass collapses that into an IROp::Select so the
// existing Select emit path (same bytes as ternary_select_f) can
// consume it byte-for-byte.
void main(
    float4 vcol : COLOR,
    uniform float4 a,
    uniform float4 b,
    out float4 color : COLOR)
{
    if (vcol.x > 0.5f)
    {
        color = a;
    }
    else
    {
        color = b;
    }
}
