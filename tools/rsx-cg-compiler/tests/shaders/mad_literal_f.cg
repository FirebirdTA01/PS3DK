// FP MAD fusion: `vcol * uniform + literal`.
//
// sce-cgc lowers this to a four-block sequence:
//
//   MOVH H0, f[COL0];                          # promote varying to fp16
//   MOVR R1, a;                                # preload multiplier uniform
//   <16-byte zero block — runtime patches a>
//   FENCBR ;                                   # fence between preload and MAD
//   MADR R0, H0, R1, {0x3dcccccd, ...};        # R0 = H0 * R1 + literal
//   <16-byte inline literal: 0.1, 0.2, 0.3, 0.4>
//
// 352-byte container.  Scheduling rule: when the Add's second
// operand is a LITERAL (unnamed), it gets inlined at MAD.SRC2 and
// the Mul's uniform multiplier is preloaded into R1.  Contrast with
// mad_uniform_f.cg where both Add operands are uniforms.
void main(
    float4 vcol : COLOR,
    uniform float4 a,
    out float4 color : COLOR)
{
    color = vcol * a + float4(0.1f, 0.2f, 0.3f, 0.4f);
}
