// Ternary Select where the FALSE-branch is a varying and the
// TRUE-branch is a uniform.  Matches the ordinary EQ pattern — the
// uniform preloads, the conditional MOV reads the varying with EQ
// (when SGT wrote 0, i.e. condition was FALSE).
//
//   SGTRC RC.x, f[COL0], {0.5, 0, 0, 0}.x;
//   <inline {0.5, 0, 0, 0}>
//   MOVR R0, a;              # trueBranch uniform preloaded
//   <inline zero for a>
//   MOVR R0(EQ.x), f[TEX0];  # conditional EQ — read varying when FALSE
void main(
    float4 vcol      : COLOR,
    float4 vt        : TEXCOORD0,
    uniform float4 a,
    out float4 color : COLOR)
{
    color = (vcol.x > 0.5f) ? a : vt;
}
