// `length(vec3)` = sqrt(dot(v, v)).  sce-cgc lowers to:
//
//   MOVH H0.xyz, f[COL0];       # promote varying to fp16 vec3
//   DP3R R0.x, H0, H0;          # dot(v, v) → R0.x
//   DIVSQR R0.x, |R0|, R0;      # R0.x = |R0.x| / sqrt(R0.x) = sqrt(R0.x)
//   MOVR R0, R0.x;              # broadcast scalar → full vec4
//
// The DIVSQR (Sony NV40+RSX extension, opcode 0x3B) computes
// src0 / sqrt(src1).  The |R0| and R0 are both the same register
// read, so mathematically |x|/sqrt(x) = sqrt(x) for x >= 0.  This
// is sce-cgc's preferred sqrt implementation.
void main(
    float4 vcol      : COLOR,
    out float4 color : COLOR)
{
    color = length(vcol.xyz);
}
