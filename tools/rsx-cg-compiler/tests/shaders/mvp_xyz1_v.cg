// VP DPH lowering test: `mul(matrix, float4(vec3, 1.0))` is the
// idiomatic Cg way to project a 3-component world-space position
// through a model-view-projection matrix.  sce-cgc lowers this to
// four DPH (dot-product-homogeneous, opcode 0x06) instructions
// that treat the source W as implicit 1.0 — saving the explicit
// vec3-to-vec4 promotion + temp register that PSL1GHT cgcomp emits.
//
// Verified byte-for-byte against sce-cgc 475.001.  Source-operand
// swizzle is `.xyzx` (replicates X into the ignored W lane); the
// dot product still uses XYZ from the input and W=1 from DPH itself.
//
// Output disasm (sce-cgcdisasm):
//   DPH o[0].w, v[0].xyzx, c[259];
//   DPH o[0].z, v[0].xyzx, c[258];
//   DPH o[0].y, v[0].xyzx, c[257];
//   DPH o[0].x, v[0].xyzx, c[256];
//   END
void main(
    float3 in_position      : POSITION,
    uniform float4x4 mvp,
    out float4 out_position : POSITION)
{
    out_position = mul(mvp, float4(in_position, 1.0f));
}
