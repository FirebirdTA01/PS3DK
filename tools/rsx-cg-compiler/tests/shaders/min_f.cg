// FP MIN: `min(vcol, uniform)` — single-instruction `MINR R0, f[COL0],
// threshold;`.  Same operand canonicalisation as MUL: src0 = INPUT
// (varying), src1 = CONST (inlined uniform).  Opcode 0x08.
void main(
    float4 vcol      : COLOR,
    uniform float4 threshold,
    out float4 color : COLOR)
{
    color = min(vcol, threshold);
}
