// Ternary Select where the TRUE-branch is a varying (vt) and the
// FALSE-branch is a uniform.  Sce-cgc reshapes the lowering:
//
//   SGTRC RC.x, f[COL0], {0.5, 0, 0, 0}.x;
//   <inline {0.5, 0, 0, 0}>
//   MOVR R0, b;                 # uniform preloaded (the FALSE branch)
//   <inline zero for b>
//   MOVR R0(NE.x), f[TEX0];     # conditional NE — read varying when
//                                  SGT wrote 1 (condition was TRUE)
//
// Rationale: the varying reads through SRC0=INPUT via INPUT_SRC in
// hw[0]; it cannot have a trailing inline block, so it must ride
// the conditional MOV.  The cond flips from EQ to NE because the
// branches are effectively swapped.
//
// Container: attributeInputMask gets both COL0 and TC0 bits; the TC0
// bit in texCoords2D is cleared because the TEXCOORD is sourced via
// a non-2D-uv path.
void main(
    float4 vcol      : COLOR,
    float4 vt        : TEXCOORD0,
    uniform float4 b,
    out float4 color : COLOR)
{
    color = (vcol.x > 0.5f) ? vt : b;
}
