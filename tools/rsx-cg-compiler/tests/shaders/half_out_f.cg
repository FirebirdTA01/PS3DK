// FP16 output: writing `half4 color : COLOR` instead of `float4 color`
// promotes R0 → H0 (the fp16 half-precision register).
//
// sce-cgc lowers this to:
//   MOVH H0, f[COL0]; END
//
// Encoding deltas from identity_f.cg:
//   - hw[0] bit 7 (OUT_REG_HALF) set
//   - hw[0] bits 22-23 (PRECISION) = 1 (FP16)
//   - CgBinaryFragmentProgram.outputFromH0 = 1 (byte 0x13 of subtype)
//
// The ucode + container layout is otherwise identical to the R0 case.
void main(
    float4 vcol     : COLOR,
    out half4 color : COLOR)
{
    color = vcol;
}
