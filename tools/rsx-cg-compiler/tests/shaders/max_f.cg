// FP MAX: `max(vcol, uniform)` — single-instruction `MAXR R0, f[COL0],
// floor_v;`.  Same operand canonicalisation as MUL: src0 = INPUT
// (varying), src1 = CONST (inlined uniform).  Opcode 0x09.
void main(
    float4 vcol      : COLOR,
    uniform float4 floor_v,
    out float4 color : COLOR)
{
    color = max(vcol, floor_v);
}
