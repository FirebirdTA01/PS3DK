// Single tex2D call: sample one sampler2D at the interpolated
// TEXCOORD0 and write to the color output.  Probes the NV40 TEX
// opcode (0x17 in NVFX_FP_OP_OPCODE_*), the per-instruction
// TEX_UNIT field at hw[0] bits 17-20, and confirms the SRC0 / 1 / 2
// encoding is identical to the MOV-from-varying case (verified
// byte-for-byte against sce-cgc on identity_f.cg).
//
// sce-cgc lowers this to a single instruction:
//   TEXR R0, f[TEX0], TEX0 ; END
// with the result.color register implicit (R0 = output[COLOR]).
void main(
    float2 uv          : TEXCOORD0,
    uniform sampler2D tex,
    out float4 color   : COLOR)
{
    color = tex2D(tex, uv);
}
