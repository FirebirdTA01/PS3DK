// FP inline-constant test: write a literal vec4 to the colour output.
//
// sce-cgc lowers this to:
//   FENCBR ;
//   MOVR R0, {0x3e800000(0.25), 0x3f000000(0.5),
//             0x3f400000(0.75), 0x3f800000(1)}; # last instruction
//   END
//
// The constant block is the 16 bytes that sit AFTER the MOV in the
// ucode blob — sce-cgc counts it toward CgBinaryFragmentProgram's
// instructionCount (3, not 2), and the MOV's SRC0 encodes type=CONST
// with SRC-index=0 pointing at that immediate block.
//
// FENCBR is opcode 0x3E with OUT_NONE set — a Sony RSX synchronisation
// primitive not in the public NV40 opcode table, verified from
// sce-cgc output.
//
// 176-byte container match against sce-cgc, first landing of inline
// FP constants.
void main(out float4 color : COLOR)
{
    color = float4(0.25f, 0.5f, 0.75f, 1.0f);
}
