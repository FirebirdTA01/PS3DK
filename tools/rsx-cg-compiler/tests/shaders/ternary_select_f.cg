// FP ternary select using the NV40 condition-code path.
//
// sce-cgc lowers `(vcol.x > 0.5f) ? a : b` to three instructions +
// two inline const blocks + one inline literal:
//
//   SGTRC RC.x, f[COL0], {0.5, 0, 0, 0}.x;   # SGT writes CC[x] only;
//                                              OUT_NONE + COND_WRITE_ENABLE +
//                                              OUT_REG=0x3F sentinel
//   <inline {0.5, 0, 0, 0}>
//   MOVR R0, a;                               # unconditional "true" case
//   <inline zero for uniform a>
//   MOVR R0(EQ.x), b;                         # conditional overwrite;
//                                              cc_cond=EQ, cc_swz=(X,X,X,X)
//   <inline zero for uniform b>
//
// Why EQ.x overwrites with b: SGT wrote 1 to CC.x when the condition
// held (vcol.x > 0.5).  The conditional MOV fires only when CC.x
// reads as EQ (zero) — i.e. when the condition was FALSE.  So the
// final R0 is `a` when true, `b` when false.
//
// 416-byte full container match against sce-cgc.  First landing of
// NV40 FP conditional execution in rsx-cg-compiler.
void main(
    float4 vcol      : COLOR,
    uniform float4 a,
    uniform float4 b,
    out float4 color : COLOR)
{
    color = (vcol.x > 0.5f) ? a : b;
}
