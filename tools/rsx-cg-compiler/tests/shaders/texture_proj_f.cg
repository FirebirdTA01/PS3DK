// FP tex2Dproj: projective texture sample — hardware divides X/Y/Z
// by W before sampling.  Single-instruction `TXPR R0, f[TEX0], TEX0;`
// (opcode 0x18).  Container difference from texture_sample_f.cg: the
// `CgBinaryFragmentProgram.texCoords2D` bit for the projective
// TEXCOORD is CLEARED — the HW needs all four lanes of the coord
// (not just xy) to perform the divide.
void main(
    float4 uv         : TEXCOORD0,
    uniform sampler2D tex,
    out float4 color  : COLOR)
{
    color = tex2Dproj(tex, uv);
}
