// saturate(x) modifier: clamp each channel to [0, 1].  Lowers to the
// SAT bit (bit 31 of hw[0]) on the producing instruction — no extra
// instruction needed on NV40 FP.
//
// sce-cgc lowers this to:
//   ADDR_sat R0, tint, f[COL0]; END
//
// The encoding differs from add_f.cg only in the top bit of hw[0]:
// add_f    word 0 logical = 0x03003e01
// sat_f    word 0 logical = 0x83003e01  (+ 1<<31 = SAT)
void main(
    float4 vcol      : COLOR,
    uniform float4 tint,
    out float4 color : COLOR)
{
    color = saturate(vcol + tint);
}
