// Ternary select where the RHS of the comparison is another varying.
//
// NV40 FP can only route ONE per-instruction INPUT varying, so
// sce-cgc cannot fit `SGT f[COL0], f[TEX0]` into a single
// instruction.  Instead it promotes the LHS lane into an H-reg
// temp first and then compares TEMP vs INPUT:
//
//   MOVH H2.x, f[COL0];             # lhs varying lane → H2.x (fp16)
//   MOVR R0, a;                      # preload true branch (reordered
//                                       ahead of SGT — different from
//                                       the literal / uniform RHS path)
//   <inline zero block for a>
//   SGTRC RC.x, H2, f[TEX0];         # SRC0=TEMP(H2), SRC1=INPUT (RHS)
//   FENCBR ;
//   MOVR R0(EQ.x), b;
//   <inline zero block for b>
//
// Choice of H2 (not H0/H1): H0 and H1 alias R0's storage, which we
// still need to write as the final output.  H2 starts at R1's
// fp16-half so it won't be clobbered by writes to R0.
//
// Container deltas:
//   - attributeInputMask gets both LHS (FrontDiffuse+BackDiffuse) and
//     RHS (Tex0) bits set.
//   - texCoords2D bit for the RHS TEXCOORD is cleared (sce-cgc signals
//     "not a 2D uv read" whenever a TC is sourced via a compare).
void main(
    float4 vcol      : COLOR,
    float4 thr       : TEXCOORD0,
    uniform float4 a,
    uniform float4 b,
    out float4 color : COLOR)
{
    color = (vcol.x > thr.x) ? a : b;
}
