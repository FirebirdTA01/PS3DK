// Vertex passthrough of POSITION + COLOR0.  sce-cgc requires every
// sce_vp_rsx shader to write HPOS, so we pair the colour passthrough
// with a POSITION passthrough.  This exercises multiple StoreOutput
// emissions in cgcomp-v2 and covers both the DEST_POS and DEST_COL0
// encoding paths.
struct VIN  { float4 pos : POSITION; float4 col : COLOR; };
struct VOUT { float4 pos : POSITION; float4 col : COLOR; };

VOUT main(VIN input)
{
    VOUT o;
    o.pos = input.pos;
    o.col = input.col;
    return o;
}
