// hello-ppu-cellgcm-triangle — fragment program.
//
// Emits the interpolated vertex colour.  No textures, no uniforms —
// the rasteriser already did the colour interpolation for us.
//
// Independent: written against the sample's documented contract, not
// derived from any vendor shader source.

void main(
    float4 in_color      : COLOR,
    out float4 out_color : COLOR)
{
    out_color = in_color;
}
